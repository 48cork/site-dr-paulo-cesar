e:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"[{\"@context\":\"https://schema.org\",\"@type\":\"Article\",\"headline\":\"Inventário judicial x extrajudicial: qual escolher?\",\"description\":\"Dois caminhos para regularizar a herança — um pelo cartório, outro pelo tribunal. Entenda a diferença, os custos e como saber qual se aplica ao seu caso.\",\"url\":\"https://rolemberg.adv.br/blog/inventario-judicial-x-extrajudicial\",\"author\":{\"@type\":\"Person\"},\"publisher\":{\"@type\":\"Organization\",\"name\":\"Dr. Paulo Rolemberg — Advogado\",\"logo\":{\"@type\":\"ImageObject\",\"url\":\"https://rolemberg.adv.br/logo.png\"}},\"timeRequired\":\"4 min de leitura\"},{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Início\",\"item\":\"https://rolemberg.adv.br\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Blog\",\"item\":\"https://rolemberg.adv.br/blog\"},{\"@type\":\"ListItem\",\"position\":3,\"name\":\"Inventário judicial x extrajudicial: qual escolher?\",\"item\":\"https://rolemberg.adv.br/blog/inventario-judicial-x-extrajudicial\"}]}]"}}],["$","section",null,{"className":"bg-gradient-to-br from-blue-700 to-blue-900 text-white py-20 px-4","children":["$","div",null,{"className":"max-w-3xl mx-auto","children":[["$","div",null,{"className":"flex flex-wrap gap-2 mb-6","children":"$undefined"}],["$","h1",null,{"className":"text-3xl md:text-4xl font-extrabold mb-6 leading-tight","children":"Inventário judicial x extrajudicial: qual escolher?"}],["$","p",null,{"className":"text-blue-100 text-lg mb-6","children":"Dois caminhos para regularizar a herança — um pelo cartório, outro pelo tribunal. Entenda a diferença, os custos e como saber qual se aplica ao seu caso."}],["$","div",null,{"className":"flex items-center gap-4 text-blue-200 text-sm","children":[["$","span",null,{"children":["Por ","$undefined"]}],["$","span",null,{"children":"·"}],["$","span",null,{"children":"Invalid Date"}],["$","span",null,{"children":"·"}],["$","span",null,{"children":"4 min de leitura"}]]}]]}]}],["$","div",null,{"className":"max-w-3xl mx-auto px-4 py-8","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Início\",\"item\":\"https://rolemberg.adv.br/\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Blog\",\"item\":\"https://rolemberg.adv.br/blog\"},{\"@type\":\"ListItem\",\"position\":3,\"name\":\"Inventário judicial x extrajudicial: qual escolher?\",\"item\":\"https://rolemberg.adv.br/blog/inventario-judicial-x-extrajudicial\"}]}"}}],["$","nav",null,{"aria-label":"Breadcrumb","className":"text-sm text-gray-500 mb-6","children":["$","ol",null,{"className":"flex flex-wrap items-center gap-2","children":[["$","li","/",{"className":"flex items-center gap-2","children":[false,["$","$L2",null,{"href":"/","className":"hover:text-blue-600 transition-colors","children":"Início"}]]}],["$","li","/blog",{"className":"flex items-center gap-2","children":[["$","span",null,{"aria-hidden":"true","children":"/"}],["$","$L2",null,{"href":"/blog","className":"hover:text-blue-600 transition-colors","children":"Blog"}]]}],["$","li","/blog/inventario-judicial-x-extrajudicial",{"className":"flex items-center gap-2","children":[["$","span",null,{"aria-hidden":"true","children":"/"}],["$","span",null,{"className":"text-gray-900 font-medium","aria-current":"page","children":"Inventário judicial x extrajudicial: qual escolher?"}]]}]]}]}]]}],["$","article",null,{"className":"max-w-3xl mx-auto px-4 pb-20","children":["$","div",null,{"className":"prose prose-lg prose-blue max-w-none","children":"$L18"}]}]]
18:[["$","p",null,{"children":"Quando alguém falece e deixa bens, a família precisa fazer o inventário. O que muita gente não sabe é que existem dois caminhos diferentes: pelo cartório ou pelo tribunal. A escolha certa depende da situação específica da família."}],"\n",["$","h2",null,{"children":"Inventário extrajudicial (em cartório)"}],"\n",["$","p",null,{"children":"O inventário extrajudicial é feito diretamente no cartório de notas, sem precisar entrar na Justiça. É mais rápido, mais barato e menos burocrático."}],"\n",["$","p",null,{"children":[["$","strong",null,{"children":"Prazo médio:"}]," de 30 a 90 dias, dependendo da documentação."]}],"\n",["$","p",null,{"children":[["$","strong",null,{"children":"Custo:"}]," custas cartorárias (variam por estado e pelo valor dos bens) + honorários do advogado. Em Sergipe, as custas do cartório ficam geralmente entre 2% e 4% do valor dos bens, além do ITCMD de 4%."]}],"\n",["$","p",null,{"children":["$","strong",null,{"children":"Requisitos para poder usar o cartório:"}]}],"\n",["$","ul",null,{"children":["\n",["$","li",null,{"children":["Todos os herdeiros devem ser ",["$","strong",null,{"children":"maiores de 18 anos"}]]}],"\n",["$","li",null,{"children":["Todos devem estar ",["$","strong",null,{"children":"de acordo"}]," com a partilha (ninguém pode discordar)"]}],"\n",["$","li",null,{"children":[["$","strong",null,{"children":"Não pode haver testamento"}]," deixado pelo falecido"]}],"\n",["$","li",null,{"children":["Todos os herdeiros devem estar ",["$","strong",null,{"children":"plenamente capazes"}]," (sem problemas mentais ou interdições)"]}],"\n"]}],"\n",["$","p",null,{"children":"Se todos esses requisitos forem atendidos, o cartório é sempre a melhor opção. O processo é mais simples e a família não precisa esperar anos por uma sentença judicial."}],"\n",["$","h3",null,{"children":"Como funciona na prática"}],"\n",["$","ol",null,{"children":["\n",["$","li",null,{"children":"O advogado levanta a documentação e prepara a minuta da escritura"}],"\n",["$","li",null,{"children":"Todos os herdeiros e o advogado assinam a escritura no cartório"}],"\n",["$","li",null,{"children":"A escritura é registrada nos cartórios competentes (imóveis, Detran, etc.)"}],"\n",["$","li",null,{"children":"Os bens são formalmente transferidos para os herdeiros"}],"\n"]}],"\n",["$","p",null,{"children":"Em Aracaju, os cartórios de notas estão concentrados principalmente no Centro e no bairro Salgado Filho."}],"\n",["$","hr",null,{}],"\n",["$","h2",null,{"children":"Inventário judicial (pelo Tribunal de Justiça)"}],"\n",["$","p",null,{"children":"O inventário judicial tramita pela Vara de Sucessões do Tribunal de Justiça de Sergipe. É necessário quando o extrajudicial não é possível."}],"\n",["$","p",null,{"children":[["$","strong",null,{"children":"Prazo médio:"}]," de 1 a 3 anos, podendo ser mais em casos complexos."]}],"\n",["$","p",null,{"children":[["$","strong",null,{"children":"Custo:"}]," custas judiciais + honorários do advogado. No geral é mais caro e demora mais que o extrajudicial."]}],"\n",["$","p",null,{"children":["$","strong",null,{"children":"Quando é obrigatório usar a via judicial:"}]}],"\n",["$","ul",null,{"children":["\n",["$","li",null,{"children":["Há ",["$","strong",null,{"children":"herdeiro menor de 18 anos"}]," (incluindo filhos, netos ou outros dependentes)"]}],"\n",["$","li",null,{"children":["O falecido deixou ",["$","strong",null,{"children":"testamento"}]]}],"\n",["$","li",null,{"children":["Há ",["$","strong",null,{"children":"conflito entre os herdeiros"}]," sobre a divisão dos bens"]}],"\n",["$","li",null,{"children":["Um herdeiro é ",["$","strong",null,{"children":"incapaz"}]," (interditado ou com curatela)"]}],"\n",["$","li",null,{"children":["Um herdeiro ",["$","strong",null,{"children":"não é localizado"}]," ou se recusa a assinar"]}],"\n",["$","li",null,{"children":["Há ",["$","strong",null,{"children":"dívidas"}]," do falecido que precisam ser cobradas ou pagas pelo espólio"]}],"\n"]}],"\n",["$","h3",null,{"children":"Como funciona na prática"}],"\n",["$","p",null,{"children":"O advogado peticiona ao juiz abrindo o inventário. Um inventariante é nomeado (geralmente o cônjuge ou um dos filhos) para administrar os bens durante o processo. Ao final, o juiz homologa a partilha e os bens são transferidos."}],"\n","$L19","\n","$L1a","\n","$L1b","\n","$L1c","\n","$L1d","\n","$L1e","\n","$L1f","\n","$L20","\n","$L21","\n","$L22","\n","$L23"]
