17:Tac9,[{"@context":"https://schema.org","@type":"LegalService","name":"Inventário Judicial em Nossa Senhora do Socorro — Dr. Paulo Rolemberg — Advogado","description":"O inventário judicial é obrigatório quando existem herdeiros menores de idade, pessoas incapazes, testamento ou quando os herdeiros não chegam a um acordo. O processo tramita na Vara de Família e Sucessões e exige acompanhamento de advogado em todas as etapas. Cuidamos de todo o trâmite: da abertura do processo até a expedição do formal de partilha.","url":"https://rolemberg.adv.br/inventario-judicial-nossa-senhora-do-socorro","areaServed":{"@type":"City","name":"Nossa Senhora do Socorro","containedInPlace":{"@type":"State","name":"Sergipe","containedInPlace":{"@type":"Country","name":"Brasil"}}},"hasOfferCatalog":{"@type":"OfferCatalog","name":"Inventário Judicial","itemListElement":[{"@type":"Offer","itemOffered":{"@type":"Service","name":"Inventário Judicial","description":"Quando há menores herdeiros, testamento ou desacordo entre as partes, o inventário precisa ser feito pela via judicial."}}]}},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Quanto tempo leva um inventário judicial?","acceptedAnswer":{"@type":"Answer","text":"Depende da complexidade do patrimônio e do volume de processos na comarca. Em média, leva de 1 a 3 anos. Casos simples e com acordo entre as partes podem ser encerrados em menos tempo."}},{"@type":"Question","name":"É possível fazer inventário judicial sem advogado?","acceptedAnswer":{"@type":"Answer","text":"Não. O inventário judicial exige obrigatoriamente a representação por advogado habilitado. Cada herdeiro pode ter seu próprio advogado ou todos podem ser representados por um único profissional, desde que não haja conflito de interesses."}},{"@type":"Question","name":"Qual a diferença entre inventário judicial e extrajudicial?","acceptedAnswer":{"@type":"Answer","text":"O extrajudicial é feito em cartório, é mais rápido e barato, mas só é permitido quando todos os herdeiros são maiores, capazes, estão de acordo e não há testamento. Quando alguma dessas condições não se aplica, o caminho é o judicial."}}]},{"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Início","item":"https://rolemberg.adv.br"},{"@type":"ListItem","position":2,"name":"Serviços","item":"https://rolemberg.adv.br/servicos"},{"@type":"ListItem","position":3,"name":"Inventário Judicial","item":"https://rolemberg.adv.br/servicos#inventario-judicial"},{"@type":"ListItem","position":4,"name":"Nossa Senhora do Socorro","item":"https://rolemberg.adv.br/inventario-judicial-nossa-senhora-do-socorro"}]}]d:[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$17"}}],["$","section",null,{"className":"bg-slate-900 text-white py-20 px-4","children":["$","div",null,{"className":"max-w-4xl mx-auto","children":[["$","p",null,{"className":"text-slate-400 text-sm font-medium mb-4 tracking-wide uppercase","children":["Dr. Paulo Cesar Rolemberg Farias"," — ","Nossa Senhora do Socorro",", ","SE"]}],["$","div",null,{"className":"text-4xl mb-5","children":"⚖️"}],["$","h1",null,{"className":"text-4xl md:text-5xl font-extrabold mb-5 leading-tight","children":["Inventário Judicial"," em ","Nossa Senhora do Socorro"]}],["$","p",null,{"className":"text-slate-300 text-lg mb-8 max-w-2xl leading-relaxed","children":"Quando há menores herdeiros, testamento ou desacordo entre as partes, o inventário precisa ser feito pela via judicial."}],"$L18"]}]}],"$L19","$L1a"]
